{
  "name": "infra-cdk",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "bootstrap:local": "cdklocal bootstrap aws://000000000000/eu-west-1",
    "deploy:local": "cdklocal deploy --app \"npx ts-node --prefer-ts-exts bin/infra-cdk.local.ts\" --require-approval never",
    "deploy:prod": "cdk deploy --app \"npx ts-node --prefer-ts-exts bin/infra-cdk.prod.ts\"",
    "synth:local": "cdklocal synth --app \"npx ts-node --prefer-ts-exts bin/infra-cdk.local.ts\"",
    "synth:prod": "cdk synth --app \"npx ts-node --prefer-ts-exts bin/infra-cdk.prod.ts\""
  },
  "devDependencies": {
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "jest": "^30",
    "ts-jest": "^29",
    "aws-cdk": "2.1122.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.256.1",
    "constructs": "^10.5.0"
  }
}
