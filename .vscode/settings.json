{
  "files.exclude": {
    // 1. Global system and language server noise
    "**/.git": true,
    "**/.DS_Store": true,
    "**/.bsp": true,
    "**/.metals": true,

    // 2. Clear out sbt root and meta build target paths entirely
    "project/project": true,
    "project/target": true,
    "target": true,
    "scala/target": true,

    // 3. Global compilation noise patterns (Matches any module anywhere)
    "**/target/**/streams": true,
    "**/target/**/classes": true,
    "**/target/**/zinc": true,
    "**/target/**/update": true,
    "**/target/**/sync": true,
    "**/target/**/resource_managed": true,
    "**/target/**/main/smithy": true
  }
}